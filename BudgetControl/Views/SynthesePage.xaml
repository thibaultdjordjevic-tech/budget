<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BudgetControl.Views.SynthesePage"
             Title="Synthèse">

    <RefreshView Command="{Binding LoadCommand}" IsRefreshing="{Binding IsBusy}">
        <ScrollView>
            <VerticalStackLayout Padding="16,12,16,32" Spacing="16">

                <!-- Navigation mois -->
                <Border StrokeShape="RoundRectangle 20" StrokeThickness="0" Padding="20,16">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#4361EE" Offset="0"/>
                            <GradientStop Color="#5E35B1" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <VerticalStackLayout Spacing="16">

                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <Button Grid.Column="0" Text="‹"
                                    Command="{Binding MoisPrecedentCommand}"
                                    BackgroundColor="Transparent"
                                    TextColor="White" FontSize="42" Padding="24"/>
                            <Label Grid.Column="1"
                                   Text="{Binding PeriodeLabel}"
                                   HorizontalOptions="Center" VerticalOptions="Center"
                                   FontSize="38" TextColor="#CCDDFF"/>
                            <Button Grid.Column="2" Text="›"
                                    Command="{Binding MoisSuivantCommand}"
                                    BackgroundColor="Transparent"
                                    TextColor="White" FontSize="42" Padding="24"/>
                        </Grid>

                        <!-- Solde net -->
                        <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                            <Label Text="Solde net" FontSize="23" TextColor="#AABBEE"
                                   HorizontalOptions="Center"/>
                            <Label Text="{Binding SoldeFormate}"
                                   FontSize="36" FontAttributes="Bold"
                                   TextColor="White" HorizontalOptions="Center"/>
                        </VerticalStackLayout>

                        <!-- Revenus / Dépenses inline -->
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <Border Grid.Column="0" BackgroundColor="#FFFFFF1A"
                                    StrokeShape="RoundRectangle 12" StrokeThickness="0" Padding="14,10">
                                <VerticalStackLayout Spacing="2">
                                    <Label Text="Revenus" FontSize="11" TextColor="#000000"/>
                                    <Label Text="{Binding TotalRevenusFormate}"
                                           FontSize="16" FontAttributes="Bold" TextColor="#06D6A0"/>
                                </VerticalStackLayout>
                            </Border>
                            <Border Grid.Column="1" BackgroundColor="#FFFFFF1A"
                                    StrokeShape="RoundRectangle 12" StrokeThickness="0" Padding="14,10">
                                <VerticalStackLayout Spacing="2">
                                    <Label Text="Dépenses" FontSize="11" TextColor="#000000"/>
                                    <Label Text="{Binding TotalDepensesFormate}"
                                           FontSize="16" FontAttributes="Bold" TextColor="#FF8A8A"/>
                                </VerticalStackLayout>
                            </Border>
                        </Grid>

                    </VerticalStackLayout>
                </Border>

                <!-- Graphique Revenus vs Dépenses -->
                <Frame Style="{StaticResource Card}" Padding="18,16">
                    <VerticalStackLayout Spacing="14">

                        <Label Text="Revenus vs Dépenses" Style="{StaticResource SectionTitle}"/>

                        <!-- Barre revenus -->
                        <VerticalStackLayout Spacing="6">
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                                <Border Grid.Column="0" BackgroundColor="#E6FBF4"
                                        StrokeShape="RoundRectangle 8" StrokeThickness="0"
                                        Padding="6,4">
                                    <Label Text="💚" FontSize="13"/>
                                </Border>
                                <Label Grid.Column="1" Text="Revenus" FontSize="13"
                                       VerticalOptions="Center"
                                       TextColor="{AppThemeBinding Light=#1A1A2E, Dark=#E6EDF3}"/>
                                <Label Grid.Column="2"
                                       Text="{Binding TotalRevenusFormate}"
                                       FontSize="13" FontAttributes="Bold"
                                       TextColor="{StaticResource IncomeGreen}"
                                       VerticalOptions="Center"/>
                            </Grid>
                            <ProgressBar Progress="{Binding ProgressRevenus}"
                                         ProgressColor="{StaticResource IncomeGreen}"
                                         HeightRequest="10"/>
                        </VerticalStackLayout>

                        <!-- Barre dépenses -->
                        <VerticalStackLayout Spacing="6">
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                                <Border Grid.Column="0" BackgroundColor="#FFEEEE"
                                        StrokeShape="RoundRectangle 8" StrokeThickness="0"
                                        Padding="6,4">
                                    <Label Text="❤️" FontSize="13"/>
                                </Border>
                                <Label Grid.Column="1" Text="Dépenses" FontSize="13"
                                       VerticalOptions="Center"
                                       TextColor="{AppThemeBinding Light=#1A1A2E, Dark=#E6EDF3}"/>
                                <Label Grid.Column="2"
                                       Text="{Binding TotalDepensesFormate}"
                                       FontSize="13" FontAttributes="Bold"
                                       TextColor="{StaticResource ExpenseRed}"
                                       VerticalOptions="Center"/>
                            </Grid>
                            <ProgressBar Progress="{Binding ProgressDepenses}"
                                         ProgressColor="{StaticResource ExpenseRed}"
                                         HeightRequest="10"/>
                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </Frame>

                <!-- Répartition des dépenses par catégorie -->
                <Label Text="Répartition des dépenses" Style="{StaticResource SectionTitle}" Margin="4,0"/>

                <CollectionView ItemsSource="{Binding SegmentsDepenses}" SelectionMode="None">
                    <CollectionView.EmptyView>
                        <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center"
                                             Margin="0,24" Spacing="8">
                            <Label Text="🎉" FontSize="40" HorizontalOptions="Center"/>
                            <Label Text="Aucune dépense ce mois-ci !"
                                   FontSize="15" HorizontalOptions="Center"
                                   TextColor="{AppThemeBinding Light=#94A3B8, Dark=#4B5563}"/>
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>

                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame Style="{StaticResource Card}" Margin="0,5" Padding="16,14">
                                <VerticalStackLayout Spacing="8">

                                    <!-- Ligne : label + montant + pourcentage -->
                                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                                        <Label Grid.Column="0"
                                               Text="{Binding Label}"
                                               FontSize="14" FontAttributes="Bold"
                                               TextColor="{AppThemeBinding Light=#1A1A2E, Dark=#E6EDF3}"
                                               VerticalOptions="Center"/>
                                        <Label Grid.Column="1"
                                               Text="{Binding Valeur, StringFormat='{0:C0}'}"
                                               FontSize="13"
                                               TextColor="{AppThemeBinding Light=#64748B, Dark=#8B949E}"
                                               VerticalOptions="Center"/>
                                        <Border Grid.Column="2"
                                                BackgroundColor="{Binding Couleur}"
                                                StrokeShape="RoundRectangle 8"
                                                StrokeThickness="0"
                                                Padding="8,4">
                                            <Label Text="{Binding Pourcentage}"
                                                   FontSize="12" FontAttributes="Bold"
                                                   TextColor="White"/>
                                        </Border>
                                    </Grid>

                                    <!-- Accent coloré -->
                                    <BoxView HeightRequest="4" CornerRadius="2"
                                             Color="{Binding Couleur}"
                                             HorizontalOptions="Fill"/>

                                </VerticalStackLayout>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>

</ContentPage>
