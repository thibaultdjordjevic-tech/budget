<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BudgetControl.Views.DepensesPage"
             Title="Dépenses">

    <Shell.TitleView>
        <Grid ColumnDefinitions="*, Auto" Padding="0,0,16,0" VerticalOptions="Center">

            <Label Grid.Column="0" 
                   Text="Dépenses" 
                   FontSize="20" FontAttributes="Bold" 
                   TextColor="White" 
                   VerticalOptions="Center"/>

            <Label Grid.Column="1" 
                   Text="+" 
                   FontSize="32" FontAttributes="Bold" 
                   TextColor="White" 
                   VerticalOptions="Center" 
                   Margin="0,0,0,4">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding NouvelleDepenseCommand}"/>
                </Label.GestureRecognizers>
            </Label>

        </Grid>
    </Shell.TitleView>

    <Grid RowDefinitions="Auto,*">

        <BoxView Grid.RowSpan="2"
                 BackgroundColor="#99000000"
                 IsVisible="{Binding IsFormVisible}"
                 ZIndex="5">
            <BoxView.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding AnnulerCommand}"/>
            </BoxView.GestureRecognizers>
        </BoxView>

        <!-- Formulaire overlay -->
        <Frame Grid.RowSpan="2" IsVisible="{Binding IsFormVisible}"
               CornerRadius="24" Padding="24,20" Margin="12" HasShadow="True" ZIndex="10"
               BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#161B22}"
               BorderColor="{AppThemeBinding Light=#E8ECF4, Dark=#30363D}"
               VerticalOptions="Center">
            <ScrollView>
                <VerticalStackLayout Spacing="16">

                    <Label Text="{Binding Formulaire.Id, Converter={StaticResource IdToTitleConverter}, ConverterParameter='Dépense'}"
                           FontSize="20" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#1A1A2E, Dark=#E6EDF3}"/>

                    <!-- Montant -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Montant (€)" FontSize="13"
                               TextColor="{AppThemeBinding Light=#64748B, Dark=#8B949E}"/>
                        <Border Style="{StaticResource InputBorder}">
                            <Entry Placeholder="Ex : 45.50"
                                   Text="{Binding Formulaire.Montant}"
                                   Keyboard="Numeric" FontSize="16"/>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Date -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Date" FontSize="13"
                               TextColor="{AppThemeBinding Light=#64748B, Dark=#8B949E}"/>
                        <Border Style="{StaticResource InputBorder}" Padding="14,4">
                            <DatePicker Date="{Binding Formulaire.Date}" Format="dd/MM/yyyy"/>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Catégorie -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Catégorie" FontSize="13"
                               TextColor="{AppThemeBinding Light=#64748B, Dark=#8B949E}"/>
                        <Border Style="{StaticResource InputBorder}" Padding="14,0" HeightRequest="52">
                            <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center">
                                <Label Grid.Column="0"
                                       Text="{Binding CategorieLabel}"
                                       VerticalOptions="Center" FontSize="15"
                                       TextColor="{AppThemeBinding Light=#1A1A2E, Dark=#E6EDF3}"/>
                                <Label Grid.Column="1" Text="▾" FontSize="16"
                                       TextColor="{AppThemeBinding Light=#94A3B8, Dark=#4B5563}"
                                       VerticalOptions="Center"/>
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding ChoisirCategorieCommand}"/>
                                </Grid.GestureRecognizers>
                            </Grid>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Description -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Description (facultatif)" FontSize="13"
                               TextColor="{AppThemeBinding Light=#64748B, Dark=#8B949E}"/>
                        <Border Style="{StaticResource InputBorder}">
                            <Entry Placeholder="Ex : courses Carrefour" FontSize="15"
                                   Text="{Binding Formulaire.Description}"/>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Boutons -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,8,0,0">
                        <Button Grid.Column="0" Text="Annuler"
                                Command="{Binding AnnulerCommand}"
                                Style="{StaticResource SecondaryButton}"/>
                        <Button Grid.Column="1" Text="Enregistrer"
                                Command="{Binding SauvegarderCommand}"
                                BackgroundColor="{StaticResource ExpenseRed}"
                                TextColor="White" CornerRadius="14"
                                HeightRequest="52" FontAttributes="Bold"/>
                    </Grid>

                    <!-- Supprimer -->
                    <Button Text="Supprimer"
                            Command="{Binding SupprimerCommand}"
                            IsVisible="{Binding Formulaire.Id, Converter={StaticResource IdToBoolConverter}}"
                            BackgroundColor="Transparent"
                            TextColor="{StaticResource ExpenseRed}" FontSize="13"/>

                </VerticalStackLayout>
            </ScrollView>
        </Frame>

        <!-- Filtre période -->
        <Frame Grid.Row="0"
               BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#161B22}"
               BorderColor="{AppThemeBinding Light=#E8ECF4, Dark=#30363D}"
               CornerRadius="0" Padding="16,10" HasShadow="False">
            <VerticalStackLayout Spacing="8">
                <Label Text="Filtrer par période" FontSize="12"
                       TextColor="{AppThemeBinding Light=#64748B, Dark=#8B949E}"/>
                <Grid ColumnDefinitions="*,32,*" ColumnSpacing="0">
                    <Border Grid.Column="0" Style="{StaticResource InputBorder}" Padding="10,2">
                        <DatePicker Date="{Binding FiltreDebut}" Format="dd/MM/yy"/>
                    </Border>
                    <Label Grid.Column="1" Text="→"
                           HorizontalOptions="Center" VerticalOptions="Center"
                           TextColor="{AppThemeBinding Light=#94A3B8, Dark=#4B5563}"/>
                    <Border Grid.Column="2" Style="{StaticResource InputBorder}" Padding="10,2">
                        <DatePicker Date="{Binding FiltreFin}" Format="dd/MM/yy"/>
                    </Border>
                </Grid>
            </VerticalStackLayout>
        </Frame>

        <!-- Liste des dépenses -->
        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding Depenses}"
                        SelectedItem="{Binding DepenseSelectionnee}"
                        SelectionMode="Single"
                        Margin="12,8,12,0">

            <CollectionView.EmptyView>
                <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Margin="0,48" Spacing="10">
                    <Label Text="💸" FontSize="52" HorizontalOptions="Center"/>
                    <Label Text="Aucune dépense sur cette période"
                           FontSize="15" HorizontalOptions="Center"
                           TextColor="{AppThemeBinding Light=#94A3B8, Dark=#4B5563}"/>
                    <Label Text="Appuyez sur + pour en ajouter une"
                           FontSize="13" HorizontalOptions="Center"
                           TextColor="{AppThemeBinding Light=#CBD5E1, Dark=#374151}"/>
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="8" />
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Style="{StaticResource Card}" Margin="0,5" Padding="14,12">
                        <Grid ColumnDefinitions="48,*,Auto" ColumnSpacing="12">

                            <!-- Icône -->
                            <Border Grid.Column="0"
                                    StrokeShape="RoundRectangle 14"
                                    StrokeThickness="0"
                                    HeightRequest="48" WidthRequest="48"
                                    BackgroundColor="#FFEEEE">
                                <Label Text="{Binding CategorieIcone}"
                                       FontSize="24"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>
                            </Border>

                            <!-- Détails -->
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                <Label Text="{Binding CategorieNom}"
                                       FontSize="14" FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light=#1A1A2E, Dark=#E6EDF3}"/>
                                <Label Text="{Binding Description}"
                                       FontSize="12"
                                       IsVisible="{Binding Description, Converter={StaticResource StringToBoolConverter}}"
                                       TextColor="{AppThemeBinding Light=#64748B, Dark=#8B949E}"
                                       LineBreakMode="TailTruncation"/>
                                <Label Text="{Binding Date, StringFormat='{0:dd MMM yyyy}'}"
                                       FontSize="11"
                                       TextColor="{AppThemeBinding Light=#94A3B8, Dark=#4B5563}"/>
                            </VerticalStackLayout>

                            <!-- Montant -->
                            <Label Grid.Column="2"
                                   Text="{Binding Montant, StringFormat='-{0:C}'}"
                                   FontSize="16" FontAttributes="Bold"
                                   TextColor="{StaticResource ExpenseRed}"
                                   VerticalOptions="Center"/>

                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</ContentPage>
