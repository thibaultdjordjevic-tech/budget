<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="BudgetControl.Views.LoginPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:BudgetControl.ViewModels"
    Shell.NavBarIsVisible="False"
    Shell.TabBarIsVisible="False">

    <ContentPage.BindingContext>
        <vm:LoginViewModel/>
    </ContentPage.BindingContext>

    <Grid RowDefinitions="300,*">
       
        <Grid Grid.Row="0">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#4361EE" Offset="0"/>
                    <GradientStop Color="#5E35B1" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>

            <Image Source="logo.png"
                   VerticalOptions="Center"
                   HorizontalOptions="Center"
                   HeightRequest="350"
                   WidthRequest="350"
                   Aspect="AspectFit"
                   Margin="0,0,0,32"/>
        </Grid>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="28,28,28,40" Spacing="0">

                <Frame CornerRadius="24" Padding="24,20" HasShadow="True"
                       BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#161B22}"
                       BorderColor="{AppThemeBinding Light=#E8ECF4, Dark=#30363D}"
                       Margin="0,-40,0,0">

                    <VerticalStackLayout Spacing="16">

                        <Label Text="{Binding PageTitle}"
                               FontSize="20" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#1A1A2E, Dark=#E6EDF3}"/>

                        <VerticalStackLayout IsVisible="{Binding IsRegisterMode}" Spacing="12">
                            <Border Style="{StaticResource InputBorder}">
                                <Entry Placeholder="Prénom"
                                       Text="{Binding Prenom}"
                                       FontSize="15"/>
                            </Border>
                            <Border Style="{StaticResource InputBorder}">
                                <Entry Placeholder="Nom"
                                       Text="{Binding Nom}"
                                       FontSize="15"/>
                            </Border>
                        </VerticalStackLayout>

                        <Border Style="{StaticResource InputBorder}">
                            <Entry Placeholder="Adresse email"
                                   Text="{Binding Email}"
                                   Keyboard="Email"
                                   FontSize="15"/>
                        </Border>

                        <Border Style="{StaticResource InputBorder}">
                            <Entry Placeholder="Mot de passe"
                                   Text="{Binding Password}"
                                   IsPassword="True"
                                   FontSize="15"/>
                        </Border>

                        <Label Text="{Binding ErrorMessage}"
                               TextColor="#FF6B6B" FontSize="13"
                               IsVisible="{Binding ErrorMessage, Converter={StaticResource StringToBoolConverter}}"/>

                        <Button Text="{Binding ActionButtonLabel}"
                                Command="{Binding LoginOrRegisterCommand}"
                                Style="{StaticResource PrimaryButton}"
                                Margin="0,4,0,0"/>

                        <ActivityIndicator IsRunning="{Binding IsBusy}"
                                           Color="{StaticResource Primary}"
                                           HeightRequest="32"/>

                        <Button Text="{Binding SwitchModeLabel}"
                                Command="{Binding SwitchModeCommand}"
                                BackgroundColor="Transparent"
                                TextColor="{StaticResource Primary}"
                                FontSize="13"/>

                    </VerticalStackLayout>
                </Frame>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>