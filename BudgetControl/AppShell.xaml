<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="BudgetControl.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:BudgetControl.Views">

    <!-- Connexion : sans onglets ni nav bar -->
    <ShellContent
        Route="LoginPage"
        ContentTemplate="{DataTemplate views:LoginPage}"
        Shell.TabBarIsVisible="False"
        Shell.NavBarIsVisible="False"/>

    <!-- Navigation par onglets -->
    <TabBar>
        <Tab Title="Accueil">
            <ShellContent Route="MainPage" ContentTemplate="{DataTemplate views:MainPage}"/>
        </Tab>
        <Tab Title="Dépenses">
            <ShellContent Route="DepensesPage" ContentTemplate="{DataTemplate views:DepensesPage}"/>
        </Tab>
        <Tab Title="Revenus">
            <ShellContent Route="RevenusPage" ContentTemplate="{DataTemplate views:RevenusPage}"/>
        </Tab>
        <Tab Title="Budgets">
            <ShellContent Route="BudgetsPage" ContentTemplate="{DataTemplate views:BudgetsPage}"/>
        </Tab>
        <Tab Title="Synthèse">
            <ShellContent Route="SynthesePage" ContentTemplate="{DataTemplate views:SynthesePage}"/>
        </Tab>
    </TabBar>

</Shell>
